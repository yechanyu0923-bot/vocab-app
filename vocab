<style>
  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
  body { background: #f7f4ef; font-family: 'Epilogue', 'Apple SD Gothic Neo', sans-serif; color: #1a1412; min-height: 100vh; }
  button { font-family: inherit; cursor: pointer; border: none; }
  button:active { transform: scale(0.97); }

.app { display: flex; flex-direction: column; align-items: center; padding: 0 20px 80px; min-height: 100vh; }
.header { width: 100%; max-width: 440px; padding: 52px 0 18px; display: flex; align-items: center; justify-content: space-between; }
.logo { font-size: 12px; font-weight: 800; letter-spacing: 0.2em; color: #b84a2e; text-transform: uppercase; }
.sub { font-size: 12px; color: #aaa; }

.card { width: 100%; max-width: 440px; background: #fff; border-radius: 22px; padding: 28px 24px; box-shadow: 0 2px 20px rgba(0,0,0,0.06); border: 1px solid #ede8e0; }

/* HOME */
.home-title { width: 100%; max-width: 440px; margin-bottom: 20px; }
.home-title h1 { font-size: 26px; font-weight: 900; letter-spacing: -0.02em; margin-bottom: 4px; font-family: ‘Playfair Display’, Georgia, serif; }
.home-title p { font-size: 13px; color: #888; }
.topic-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; width: 100%; max-width: 440px; }
.topic-btn { background: #fff; color: #1a1412; border: 1.5px solid #ede8e0; border-radius: 16px; padding: 18px 12px; font-size: 14px; font-weight: 600; display: flex; flex-direction: column; align-items: center; gap: 5px; transition: all 0.12s; }
.topic-btn.selected { background: #b84a2e; color: #fff; border-color: #b84a2e; box-shadow: 0 4px 14px rgba(184,74,46,0.25); }
.topic-btn .emoji { font-size: 26px; }
.topic-btn .count { font-size: 11px; opacity: 0.6; }
.start-btn { width: 100%; max-width: 440px; background: #b84a2e; color: #fff; border-radius: 14px; padding: 17px; font-size: 15px; font-weight: 700; margin-top: 10px; opacity: 0.4; transition: opacity 0.15s; }
.start-btn.ready { opacity: 1; }

/* PROGRESS BAR */
.prog-row { width: 100%; max-width: 440px; display: flex; align-items: center; gap: 10px; margin-bottom: 16px; }
.prog-label { font-size: 12px; color: #888; white-space: nowrap; }
.prog-score { font-size: 12px; color: #b84a2e; font-weight: 700; white-space: nowrap; }
.prog-bar { flex: 1; height: 5px; background: #ede8e0; border-radius: 4px; overflow: hidden; }
.prog-fill { height: 100%; background: #b84a2e; border-radius: 4px; transition: width 0.3s; }

/* QUIZ */
.word-display { font-size: 44px; font-weight: 900; letter-spacing: -0.03em; font-family: ‘Playfair Display’, Georgia, serif; text-align: center; line-height: 1.1; margin: 8px 0 6px; }
.word-hint { font-size: 13px; color: #bbb; text-align: center; margin-bottom: 20px; }
.opt-btn { width: 100%; border-radius: 12px; padding: 14px 16px; font-size: 15px; font-weight: 500; text-align: left; margin-bottom: 8px; transition: all 0.12s; background: #faf8f5; border: 1.5px solid #ede8e0; color: #1a1412; }
.opt-btn.correct { background: #e8f5e9; border-color: #66bb6a; color: #2e7d32; }
.opt-btn.wrong { background: #fdecea; border-color: #ef5350; color: #c62828; }
.opt-btn.reveal-correct { background: #e8f5e9; border-color: #66bb6a; color: #2e7d32; }
.result-badge { display: inline-block; border-radius: 8px; padding: 4px 12px; font-size: 13px; font-weight: 700; margin-top: 4px; }
.result-badge.ok { background: #e8f5e9; color: #2e7d32; }
.result-badge.fail { background: #fdecea; color: #c62828; }
.example-box { background: #fffbf5; border-left: 3px solid #b84a2e; border-radius: 10px; padding: 12px 14px; font-size: 14px; color: #555; line-height: 1.7; margin-top: 12px; }
.next-btn { width: 100%; background: #1a1412; color: #fff; border-radius: 12px; padding: 15px; font-size: 14px; font-weight: 700; margin-top: 14px; }
.ghost-btn { width: 100%; background: #fff; color: #1a1412; border: 1.5px solid #ede8e0; border-radius: 12px; padding: 15px; font-size: 14px; font-weight: 700; margin-top: 8px; }

/* RESULT */
.score-ring { width: 96px; height: 96px; border-radius: 50%; border: 3px solid #b84a2e; display: flex; flex-direction: column; align-items: center; justify-content: center; margin: 0 auto 20px; }
.score-num { font-size: 26px; font-weight: 900; color: #b84a2e; }
.score-pct { font-size: 11px; color: #aaa; }
.result-msg { font-size: 22px; font-weight: 800; margin-bottom: 4px; text-align: center; }
.result-topic { font-size: 13px; color: #888; text-align: center; margin-bottom: 24px; }

/* REVIEW */
.review-label { font-size: 11px; color: #b84a2e; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 12px; }
.review-korean { font-size: 20px; color: #444; margin: 14px 0 4px; font-weight: 600; }
</style>

