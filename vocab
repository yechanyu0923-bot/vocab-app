    { word: "complimentary", korean: "무료 제공되는", example: "Dessert is complimentary today." },
    { word: "reservation", korean: "예약", example: "I made a reservation for 7 PM." },
    { word: "refill", korean: "리필하다", example: "Can I get a refill on my water?" },
    { word: "greasy", korean: "기름진", example: "The food was too greasy for me." },
    { word: "savory", korean: "짭짤하고 맛있는", example: "I prefer savory food over sweet." },
    { word: "leftover", korean: "남은 음식", example: "I'll pack up the leftovers." },
    { word: "vegetarian", korean: "채식주의자 / 채식의", example: "Is there a vegetarian option?" },
    { word: "ingredient", korean: "재료", example: "What are the main ingredients?" },
    { word: "rich", korean: "진한 / 풍부한 맛의", example: "The sauce is very rich." },
    { word: "allergic", korean: "알레르기가 있는", example: "I'm allergic to shellfish." },
    { word: "crispy", korean: "바삭바삭한", example: "The chicken skin is perfectly crispy." },
    { word: "mild", korean: "맵지 않은 / 순한", example: "I'd prefer something mild." },
    { word: "bill", korean: "계산서", example: "Can we get the bill, please?" },
    { word: "split", korean: "나누다 / 더치페이하다", example: "Should we split the bill?" },
    { word: "well-done", korean: "완전히 익힌", example: "I'd like my steak well-done." },
    { word: "medium-rare", korean: "반 정도 익힌", example: "I'll have mine medium-rare." },
    { word: "seasonal", korean: "제철의", example: "This dish uses seasonal vegetables." },
    { word: "on the house", korean: "무료 제공", example: "The drinks are on the house tonight." },
    { word: "wrap up", korean: "포장하다 / 마무리하다", example: "Can you wrap up the rest to go?" },
    { word: "appetizing", korean: "식욕을 돋우는", example: "That smells so appetizing." },
  ],
};

const TOPICS = [
  { id: "daily", label: "일상 대화", emoji: "💬" },
  { id: "emotion", label: "감정 표현", emoji: "❤️" },
  { id: "opinion", label: "의견 말하기", emoji: "💡" },
  { id: "work", label: "직장/업무", emoji: "💼" },
  { id: "travel", label: "여행", emoji: "✈️" },
  { id: "food", label: "음식/식당", emoji: "🍜" },
];

const totalWords = Object.values(WORD_DB).flat().length;

// State
let state = {
  screen: 'home',
  topic: null,
  quiz: [],
  idx: 0,
  chosen: null,
  score: 0,
  wrong: [],
  reviewIdx: 0,
  showEx: false,
};

function shuffle(arr) { return [...arr].sort(() => Math.random() - 0.5); }

function getOptions(correct, pool) {
  const others = shuffle(pool.filter(w => w.korean !== correct)).slice(0, 3).map(w => w.korean);
  return shuffle([correct, ...others]);
}

function prepareQuiz(topicId) {
  const pool = WORD_DB[topicId];
  return shuffle(pool).slice(0, 8).map(w => ({ ...w, options: getOptions(w.korean, pool) }));
}

function setState(patch) {
  Object.assign(state, patch);
  render();
}

function render() {
  const app = document.getElementById('app');
  if (state.screen === 'home') app.innerHTML = renderHome();
  else if (state.screen === 'quiz') app.innerHTML = renderQuiz();
  else if (state.screen === 'result') app.innerHTML = renderResult();
  else if (state.screen === 'review') app.innerHTML = renderReview();
  attachEvents();
}

function renderHome() {
  const topicBtns = TOPICS.map(t => `
    <button class="topic-btn ${state.topic?.id === t.id ? 'selected' : ''}" data-action="selectTopic" data-id="${t.id}">
      <span class="emoji">${t.emoji}</span>
      <span>${t.label}</span>
      <span class="count">${WORD_DB[t.id].length}개</span>
    </button>
  `).join('');

  return `
    <div class="header">
      <span class="logo">VOCAB</span>
      <span class="sub">COCA 기반 · ${totalWords}개</span>
    </div>
    <div class="home-title">
      <h1>오늘 뭐 외울까?</h1>
      <p>주제 선택 → 8문제 → 틀린 단어 복습</p>
    </div>
    <div class="topic-grid">${topicBtns}</div>
    <button class="start-btn ${state.topic ? 'ready' : ''}" data-action="startQuiz">시작하기 →</button>
  `;
}

function renderQuiz() {
  const cur = state.quiz[state.idx];
  const pct = (state.idx / state.quiz.length) * 100;

  const opts = cur.options.map(o => {
    let cls = 'opt-btn';
    if (state.chosen !== null) {
      if (o === cur.korean) cls += ' reveal-correct';
      if (o === state.chosen && o !== cur.korean) cls += ' wrong';
      if (o === state.chosen && o === cur.korean) cls = 'opt-btn correct';
    }
    return `<button class="${cls}" data-action="pick" data-opt="${o}" ${state.chosen ? 'disabled' : ''}>${o}</button>`;
  }).join('');

  const isRight = state.chosen === cur.korean;
  const feedback = state.showEx ? `
    <span class="result-badge ${isRight ? 'ok' : 'fail'}">${isRight ? '✓ 정답!' : `✗ 정답: ${cur.korean}`}</span>
    <div class="example-box">💬 ${cur.example}</div>
    <button class="next-btn" data-action="next">${state.idx + 1 >= state.quiz.length ? '결과 보기' : '다음 →'}</button>
  ` : '';

  return `
    <div class="header">
      <span class="logo">VOCAB</span>
      <span class="sub">${state.topic.label}</span>
    </div>
    <div class="prog-row">
      <span class="prog-label">${state.idx + 1} / ${state.quiz.length}</span>
      <div class="prog-bar"><div class="prog-fill" style="width:${pct}%"></div></div>
      <span class="prog-score">🔥 ${state.score}</span>
    </div>
    <div class="card">
      <div class="word-display">${cur.word}</div>
      <div class="word-hint">이 단어의 뜻은?</div>
      ${opts}
      ${feedback}
    </div>
  `;
}

function renderResult() {
  const pct = Math.round((state.score / state.quiz.length) * 100);
  const msg = pct === 100 ? '완벽해! 🎉' : pct >= 75 ? '잘했어! 👍' : pct >= 50 ? '조금 더 해보자 💪' : '다시 해보자 🔁';
  const reviewBtn = state.wrong.length > 0
    ? `<button class="ghost-btn" data-action="startReview">틀린 단어 복습 (${state.wrong.length}개) →</button>`
    : '';
  return `
    <div class="header"><span class="logo">VOCAB</span></div>
    <div class="card">
      <div class="score-ring">
        <span class="score-num">${state.score}/${state.quiz.length}</span>
        <span class="score-pct">${pct}%</span>
      </div>
      <div class="result-msg">${msg}</div>
      <div class="result-topic">${state.topic.label} 완료</div>
      ${reviewBtn}
      <button class="next-btn" data-action="retry">같은 주제 다시</button>
      <button class="ghost-btn" data-action="goHome">다른 주제 선택</button>
    </div>
  `;
}

function renderReview() {
  const w = state.wrong[state.reviewIdx];
  return `
    <div class="header">
      <span class="logo">VOCAB</span>
      <span class="sub">복습 ${state.reviewIdx + 1}/${state.wrong.length}</span>
    </div>
    <div class="card">
      <div class="review-label">틀린 단어</div>
      <div class="word-display">${w.word}</div>
      <div class="review-korean">${w.korean}</div>
      <div class="example-box">💬 ${w.example}</div>
      <button class="next-btn" data-action="nextReview">${state.reviewIdx + 1 >= state.wrong.length ? '완료 → 홈' : '다음 →'}</button>
    </div>
  `;
}

function attachEvents() {
  document.querySelectorAll('[data-action]').forEach(el => {
    el.addEventListener('click', () => {
      const action = el.dataset.action;
      if (action === 'selectTopic') {
        const t = TOPICS.find(t => t.id === el.dataset.id);
        setState({ topic: t });
      }
      else if (action === 'startQuiz') {
        if (!state.topic) return;
        setState({ screen: 'quiz', quiz: prepareQuiz(state.topic.id), idx: 0, score: 0, wrong: [], chosen: null, showEx: false });
      }
      else if (action === 'pick') {
        if (state.chosen !== null) return;
        const opt = el.dataset.opt;
        const cur = state.quiz[state.idx];
        const correct = opt === cur.korean;
        setState({ chosen: opt, showEx: true, score: correct ? state.score + 1 : state.score, wrong: correct ? state.wrong : [...state.wrong, cur] });
      }
      else if (action === 'next') {
        if (state.idx + 1 >= state.quiz.length) setState({ screen: 'result' });
        else setState({ idx: state.idx + 1, chosen: null, showEx: false });
      }
      else if (action === 'startReview') setState({ screen: 'review', reviewIdx: 0 });
      else if (action === 'retry') setState({ screen: 'quiz', quiz: prepareQuiz(state.topic.id), idx: 0, score: 0, wrong: [], chosen: null, showEx: false });
      else if (action === 'goHome') setState({ screen: 'home' });
      else if (action === 'nextReview') {
        if (state.reviewIdx + 1 >= state.wrong.length) setState({ screen: 'home' });
        else setState({ reviewIdx: state.reviewIdx + 1 });
      }
    });
  });
}

render();
</script>

</body>
</html>